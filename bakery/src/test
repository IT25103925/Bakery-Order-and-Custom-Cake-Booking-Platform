package com.example.bakery;

import com.example.bakery.model.*;
import com.example.bakery.util.FileStorage;
import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.*;

/**
 * Unit Tests for SE1020 OOP Concepts.
 * Tests cover: Inheritance, Polymorphism, Encapsulation, Exception Handling.
 */
class BakeryApplicationTests {

    // ---- Member 01: Inheritance Tests ----
    @Test
    void testCustomerInheritsFromUser() {
        Customer c = new Customer(1, "john", "pass", "john@test.com", "0771234567", "123 Main St");
        // Polymorphism: Customer IS-A User
        User u = c;
        assertEquals("john", u.getUsername());
        assertEquals("CUSTOMER", u.getRole());
        // Abstract method overriding (Lecture 04)
        assertEquals("/customer/dashboard", c.getDashboardPath());
    }

    @Test
    void testStaffInheritsFromUser() {
        Staff s = new Staff(2, "admin", "pass", "admin@test.com", "0112345678", "Manager", 85000);
        User u = s;
        assertEquals("STAFF", u.getRole());
        assertEquals("/staff/dashboard", s.getDashboardPath());
    }

    // ---- Member 02: Polymorphism Tests ----
    @Test
    void testPolymorphicProductPricing() {
        // Runtime polymorphism - same method, different behavior (Lecture 04)
        Product perishable = new PerishableProduct(1, "Bread", "Fresh", 350.0, 20, "BREAD", "2025-12-31");
        Product nonPerishable = new NonPerishableProduct(2, "Cookies", "Crispy", 320.0, 50, "COOKIE", 90);

        assertTrue(perishable.getDisplayPrice().contains("350.00"));
        assertTrue(nonPerishable.getDisplayPrice().contains("320.00"));
        assertNotEquals(perishable.getType(), nonPerishable.getType());
    }

    @Test
    void testPerishableProductWithDiscount() {
        PerishableProduct p = new PerishableProduct(1, "Old Bread", "Day-old", 350.0, 5, "BREAD", "2025-12-31");
        p.setDiscountRate(0.20);
        // Polymorphism - overridden method shows discounted price
        String display = p.getDisplayPrice();
        assertTrue(display.contains("20% off"), "Display should show discount: " + display);
    }

    // ---- Member 04: Inheritance in Cake hierarchy ----
    @Test
    void testCakeInheritance() {
        BirthdayCake bc = new BirthdayCake(1, 3, "John", "Chocolate", 2, "Happy Birthday!", "2025-12-25", "Unicorn", "5");
        WeddingCake wc = new WeddingCake(2, 4, "Sarah", "Vanilla", 4, "Forever", "2025-12-20", "John & Jane", "Fondant");

        // BirthdayCake and WeddingCake both extend CustomCake
        CustomCake cake1 = bc;
        CustomCake cake2 = wc;

        assertEquals("BIRTHDAY", cake1.getCakeType());
        assertEquals("WEDDING", cake2.getCakeType());
        // Overridden calculateBasePrice - Wedding cakes cost more
        assertTrue(wc.calculateBasePrice() > bc.calculateBasePrice(), "Wedding cake should cost more than birthday cake");
    }

    // ---- Member 05: Polymorphism in Supplier hierarchy ----
    @Test
    void testSupplierPolymorphism() {
        Supplier local = new LocalSupplier(1, "Local Farm", "local@farm.lk", "0771234567", "Colombo", "Colombo");
        Supplier wholesale = new WholesaleSupplier(2, "Big Wholesale", "bw@corp.lk", "0112345678", "Kelaniya", 100);

        // Polymorphism - same getDiscountRate(), different result (Lecture 04)
        assertEquals(0.05, local.getDiscountRate(), 0.001);
        assertEquals(0.15, wholesale.getDiscountRate(), 0.001);
        assertEquals("LOCAL", local.getSupplierType());
        assertEquals("WHOLESALE", wholesale.getSupplierType());
    }

    // ---- Member 06: Information Hiding ----
    @Test
    void testInformationHiding() {
        Review r = new Review(1, 3, "johnsmith", 1, "Bread", 5, "Great!", "2025-12-01");
        // Information hiding - username masked in public display (Lecture 01)
        String masked = r.getMaskedUsername();
        assertFalse(masked.equals("johnsmith"), "Username should be masked");
        assertTrue(masked.startsWith("j"), "Masked name should start with first letter");
        assertTrue(masked.contains("***"), "Masked name should contain ***");
    }

    // ---- Encapsulation Test ----
    @Test
    void testEncapsulation() {
        Customer c = new Customer();
        // All fields private - must use setters (Lecture 01, 02)
        c.setUsername("testuser");
        c.setEmail("test@example.com");
        c.setLoyaltyPoints(100);

        assertEquals("testuser", c.getUsername());
        assertEquals("test@example.com", c.getEmail());
        assertEquals(100, c.getLoyaltyPoints());
    }

    // ---- Static Method Test (Lecture 05) ----
    @Test
    void testStaticGenerateId() {
        java.util.List<String> lines = new java.util.ArrayList<>();
        lines.add("1,admin,pass,admin@test.com,0112345678,STAFF,Manager,85000");
        lines.add("3,john,pass,john@test.com,0771234567,CUSTOMER,123 Main St,0");
        // Static method - called on class, not instance (Lecture 05)
        int nextId = FileStorage.generateId(lines);
        assertEquals(4, nextId);
    }

    // ---- toString / CSV serialization ----
    @Test
    void testUserSerialization() {
        Customer c = new Customer(1, "john", "pass123", "john@test.com", "0771234567", "123 Main St", 50);
        String csv = c.toString();
        assertTrue(csv.contains("john"));
        assertTrue(csv.contains("CUSTOMER"));
        assertTrue(csv.contains("50"));
    }

    @Test
    void testOrderItemSubtotal() {
        OrderItem item = new OrderItem(1, "Bread", 3, 350.0);
        assertEquals(1050.0, item.getSubtotal(), 0.001);
    }
}
